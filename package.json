{
  "name": "buildkit-crm",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:portal": "npm run dev -w apps/portal",
    "dev:portal-api": "npm run dev -w apps/portal-api",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "npx tsx packages/shared/src/seed.ts",
    "dev:worker": "npm run dev -w apps/worker",
    "test": "npm run test -w apps/api"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
